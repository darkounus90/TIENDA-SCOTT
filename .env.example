# Variables de entorno — copiar este archivo a .env y completar valores reales
# NUNCA subir .env al repositorio

# =====================================
# BASE DE DATOS (PHP Backend)
# =====================================
DB_HOST=localhost
DB_USER=c2721903_scott
DB_PASS=TU_CONTRASEÑA_NUEVA_AQUI
DB_NAME=c2721903_scott

# =====================================
# AUTENTICACIÓN (PHP tokens)
# =====================================
# Generar con: openssl rand -hex 32
TOKEN_SECRET=GENERAR_CON_OPENSSL_RAND_HEX_32

# Entorno: 'production' o 'development'
APP_ENV=production

# CORS: Tu dominio real (sin barra al final)
ALLOWED_ORIGIN=https://bikeclubpedalazo.online

# =====================================
# GOOGLE OAUTH
# =====================================
# Obtener en: console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=TU_CLIENT_ID.apps.googleusercontent.com

# =====================================
# WOMPI (Pagos)
# =====================================
# Obtener en: comercios.wompi.co → Configuración → Webhooks
WOMPI_WEBHOOK_SECRET=TU_SECRETO_DE_WEBHOOK_WOMPI
# Llaves de Wompi
WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXX
WOMPI_PRIVATE_KEY=prv_test_XXXXXXXXXXXX

# =====================================
# NODE.JS BACKEND (Migración futura)
# =====================================
PORT=3000
NODE_ENV=production

# =====================================
# CLOUDINARY (Imágenes — Fase 5)
# =====================================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret